# ── Database ─────────────────────────────────────────────────────────────────
# Set this to use PostgreSQL (Supabase). Leave unset to use local SQLite.
DATABASE_URL=postgresql://postgres.YOURPROJECT:PASSWORD@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres

# ── AI APIs ───────────────────────────────────────────────────────────────────
# Gemini — used for embeddings (pgvector search) and the chat assistant.
GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE

# Anthropic — Phase D2 insights (optional, dashboard works without it)
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY_HERE

# ── Server ────────────────────────────────────────────────────────────────────
PORT=7842
