# ── Database ─────────────────────────────────────────────────────────────────
# Set this to use PostgreSQL (Supabase). Leave unset to use local SQLite.
DATABASE_URL=postgresql://postgres.YOURPROJECT:PASSWORD@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres

# ── Auth ─────────────────────────────────────────────────────────────────────
# Comma-separated user_id:token pairs. Leave unset for single-user local mode.
# Generate tokens with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ALLOWED_TOKENS=yash:YOUR_TOKEN_HERE,alice:ALICE_TOKEN_HERE,bob:BOB_TOKEN_HERE

# ── AI APIs ───────────────────────────────────────────────────────────────────
# Gemini — used for vector embeddings (pgvector search). Required when DATABASE_URL is set.
GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE

# Anthropic — used for Phase D2 insights (optional, dashboard works without it)
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY_HERE

# ── Server ────────────────────────────────────────────────────────────────────
PORT=7842
